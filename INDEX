<script>
  // ---------- nav active state ----------
  const navLinks=[...document.querySelectorAll('#nav a')];
  const sections=navLinks.map(a=>document.querySelector(a.getAttribute('href')));
  const onScroll=()=>{
    let idx=0;const y=window.scrollY+70;
    sections.forEach((s,i)=>{if(s.offsetTop<=y)idx=i;});
    navLinks.forEach((a,i)=>a.classList.toggle('active',i===idx));
  };
  window.addEventListener('scroll',onScroll,{passive:true});onScroll();

  // ---------- checklist + persistence ----------
  const STORE_KEY='ipma-trip-checks';
  let state={};

  // give each checkable row a stable id from its text
  const rows=[...document.querySelectorAll('.check')].filter(r=>r.querySelector('.box'));
  rows.forEach((row,i)=>{
    const txt=(row.querySelector('.c-title')?.textContent||'').slice(0,40);
    row.dataset.id=i+'::'+txt;
  });

  function applyState(){
    rows.forEach(row=>{
      const on=!!state[row.dataset.id];
      row.classList.toggle('done',on);
    });
    updateProgress();
  }

  function updateProgress(){
    [['sched','prog-sched','bar-sched'],['pack','prog-pack','bar-pack']].forEach(([track,pId,bId])=>{
      const trackRows=rows.filter(r=>r.closest('[data-track="'+track+'"]'));
      const done=trackRows.filter(r=>r.classList.contains('done')).length;
      const total=trackRows.length;
      const pEl=document.getElementById(pId),bEl=document.getElementById(bId);
      if(pEl)pEl.textContent=done+' of '+total;
      if(bEl)bEl.style.width=(total?Math.round(done/total*100):0)+'%';
    });
  }

  function save(){
    try{localStorage.setItem(STORE_KEY,JSON.stringify(state));}
    catch(e){console.warn('save failed',e);}
  }

  function load(){
    try{
      const raw=localStorage.getItem(STORE_KEY);
      if(raw)state=JSON.parse(raw);
    }catch(e){state={};}
    applyState();
  }

  rows.forEach(row=>{
    row.addEventListener('click',()=>{
      const id=row.dataset.id;
      state[id]=!state[id];
      row.classList.toggle('done',state[id]);
      updateProgress();
      save();
    });
  });

  load();
</script>
