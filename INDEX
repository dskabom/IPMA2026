<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IPMA 2026 — Trip Companion · Dan Duersch</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Libre+Franklin:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#122441;
    --navy-soft:#1c3457;
    --ink:#1b222e;
    --paper:#f6f2ea;
    --paper-2:#efe8db;
    --card:#fffdf8;
    --gold:#bd7d33;
    --gold-deep:#9a611f;
    --teal:#2c6e69;
    --line:rgba(18,36,65,.14);
    --line-strong:rgba(18,36,65,.28);
    --shadow:0 1px 2px rgba(18,36,65,.06),0 8px 24px rgba(18,36,65,.08);
    --muted:#5c6675;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    font-family:"Libre Franklin",system-ui,sans-serif;
    background:var(--paper);
    color:var(--ink);
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
    padding-bottom:64px;
  }
  /* ---- Hero ---- */
  .hero{
    background:
      radial-gradient(120% 120% at 85% -10%, rgba(189,125,51,.30), transparent 55%),
      radial-gradient(120% 120% at 0% 110%, rgba(44,110,105,.30), transparent 50%),
      linear-gradient(160deg,var(--navy),var(--navy-soft));
    color:#f7f3ec;
    padding:38px 22px 30px;
    position:relative;
    overflow:hidden;
  }
  .hero::after{
    content:"";position:absolute;inset:0;
    background-image:radial-gradient(rgba(255,255,255,.05) 1px,transparent 1px);
    background-size:14px 14px;opacity:.5;pointer-events:none;
  }
  .hero .kicker{
    font-size:.72rem;letter-spacing:.28em;text-transform:uppercase;
    color:var(--gold);font-weight:600;margin-bottom:14px;
  }
  .hero h1{
    font-family:"Fraunces",serif;font-weight:600;font-size:2.35rem;
    line-height:1.02;letter-spacing:-.01em;margin-bottom:6px;
  }
  .hero h1 em{font-style:italic;color:#f2c98a;font-weight:500}
  .hero .sub{font-size:1rem;color:#cdd6e3;font-weight:400;max-width:30ch}
  .hero .meta{
    display:flex;flex-wrap:wrap;gap:8px;margin-top:18px;
  }
  .chip{
    background:rgba(255,255,255,.10);border:1px solid rgba(255,255,255,.18);
    padding:5px 11px;border-radius:999px;font-size:.78rem;font-weight:500;
    color:#eef2f8;backdrop-filter:blur(4px);
  }
  /* ---- Nav ---- */
  nav{
    position:sticky;top:0;z-index:40;background:rgba(246,242,234,.93);
    backdrop-filter:blur(10px);border-bottom:1px solid var(--line);
    display:flex;overflow-x:auto;scrollbar-width:none;
  }
  nav::-webkit-scrollbar{display:none}
  nav a{
    flex:0 0 auto;padding:13px 16px;font-size:.82rem;font-weight:600;
    color:var(--muted);text-decoration:none;white-space:nowrap;
    border-bottom:2px solid transparent;letter-spacing:.02em;
  }
  nav a.active{color:var(--navy);border-bottom-color:var(--gold)}
  main{max-width:760px;margin:0 auto;padding:8px 16px 0}
  section{padding:26px 0 8px;scroll-margin-top:54px}
  .sec-head{display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-bottom:4px}
  h2{
    font-family:"Fraunces",serif;font-weight:600;font-size:1.5rem;
    color:var(--navy);letter-spacing:-.01em;
  }
  .sec-note{font-size:.82rem;color:var(--muted);margin:2px 0 16px}
  h3.day{
    font-family:"Fraunces",serif;font-size:1.06rem;color:var(--navy);
    margin:22px 0 2px;display:flex;align-items:center;gap:9px;
  }
  h3.day .dot{width:8px;height:8px;border-radius:50%;background:var(--gold);flex:0 0 auto}
  h3.day small{font-family:"Libre Franklin";font-weight:500;color:var(--muted);font-size:.74rem;letter-spacing:.04em}
  /* ---- Cards ---- */
  .card{
    background:var(--card);border:1px solid var(--line);border-radius:14px;
    padding:16px 16px 6px;margin-bottom:14px;box-shadow:var(--shadow);
  }
  .card.flush{padding-bottom:14px}
  .callout{
    border-left:3px solid var(--gold);background:linear-gradient(90deg,rgba(189,125,51,.09),transparent);
    border-radius:10px;padding:13px 15px;margin-bottom:14px;font-size:.9rem;
  }
  .callout.alert{border-left-color:#b4452f;background:linear-gradient(90deg,rgba(180,69,47,.10),transparent)}
  .callout strong{color:var(--navy)}
  /* ---- Checklist ---- */
  .check{
    display:flex;gap:11px;align-items:flex-start;padding:9px 2px;
    border-bottom:1px solid var(--line);cursor:pointer;user-select:none;
  }
  .check:last-child{border-bottom:none}
  .box{
    flex:0 0 auto;width:20px;height:20px;margin-top:2px;border-radius:6px;
    border:2px solid var(--line-strong);background:#fff;position:relative;
    transition:all .15s ease;
  }
  .check.done .box{background:var(--teal);border-color:var(--teal)}
  .box::after{
    content:"";position:absolute;left:5.5px;top:1.5px;width:5px;height:10px;
    border:solid #fff;border-width:0 2.5px 2.5px 0;transform:rotate(45deg) scale(0);
    transition:transform .15s ease;
  }
  .check.done .box::after{transform:rotate(45deg) scale(1)}
  .c-body{flex:1;min-width:0}
  .c-time{font-size:.74rem;font-weight:700;color:var(--gold-deep);letter-spacing:.03em}
  .c-title{font-size:.93rem;font-weight:500;color:var(--ink)}
  .check.done .c-title{color:var(--muted);text-decoration:line-through;text-decoration-color:var(--line-strong)}
  .c-loc{font-size:.76rem;color:var(--muted)}
  .star{
    display:inline-block;font-size:.64rem;font-weight:700;color:var(--gold-deep);
    background:rgba(189,125,51,.14);border:1px solid rgba(189,125,51,.3);
    padding:1px 6px;border-radius:999px;margin-left:6px;letter-spacing:.06em;vertical-align:middle;
  }
  .conflict{
    border:1px solid rgba(180,69,47,.4);background:rgba(180,69,47,.05);
    border-radius:11px;padding:4px 11px 2px;margin:8px 0;
  }
  .cbadge{
    display:inline-block;font-size:.62rem;font-weight:700;color:#fff;
    background:#b4452f;padding:2px 9px;border-radius:999px;letter-spacing:.07em;
    margin:6px 0 2px;text-transform:uppercase;
  }
  .conflict .check{border-bottom:1px dashed rgba(180,69,47,.25)}
  .conflict .check:last-child{border-bottom:none}
  /* ---- Restaurants ---- */
  .rest{display:flex;gap:13px;padding:13px 0;border-bottom:1px solid var(--line);align-items:flex-start}
  .rest:last-child{border-bottom:none}
  .rest .rating{
    flex:0 0 auto;width:44px;height:44px;border-radius:11px;background:var(--navy);
    color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;
    font-weight:700;font-size:.95rem;line-height:1;
  }
  .rest .rating span{font-size:.52rem;font-weight:600;color:#f2c98a;margin-top:2px;letter-spacing:.05em}
  .rest .rb{flex:1;min-width:0}
  .rest .rname{font-weight:600;font-size:.96rem;color:var(--navy)}
  .rest .rtag{font-size:.74rem;color:var(--gold-deep);font-weight:600;text-transform:uppercase;letter-spacing:.05em}
  .rest .rdesc{font-size:.84rem;color:var(--ink);margin-top:3px}
  .rest .rmeta{font-size:.74rem;color:var(--muted);margin-top:4px}
  .walk{
    display:inline-block;font-size:.68rem;font-weight:600;color:var(--teal);
    background:rgba(44,110,105,.12);padding:1px 7px;border-radius:999px;margin-right:6px;
  }
  /* ---- Progress ---- */
  .prog{font-size:.74rem;color:var(--muted);font-weight:600}
  .barwrap{height:5px;background:var(--paper-2);border-radius:999px;overflow:hidden;margin:6px 0 2px}
  .bar{height:100%;background:linear-gradient(90deg,var(--teal),var(--gold));width:0;transition:width .3s ease;border-radius:999px}
  /* ---- Misc ---- */
  .twocol{display:grid;grid-template-columns:1fr;gap:0}
  .leg{font-size:.78rem;color:var(--muted);margin-top:10px;display:flex;align-items:center;gap:6px}
  footer{text-align:center;padding:30px 20px;color:var(--muted);font-size:.76rem}
  footer .wm{font-family:"Fraunces",serif;font-style:italic;color:var(--navy);font-size:.95rem}
  a.inline{color:var(--gold-deep);font-weight:600;text-decoration:none;border-bottom:1px solid rgba(189,125,51,.4)}
  .ix{font-size:.8rem;color:var(--muted);font-style:italic;margin:2px 0 12px}
  @media print{
    nav{display:none}body{background:#fff;padding:0}
    .card,.callout{box-shadow:none;break-inside:avoid}
    .hero{color:#000;background:#fff;border-bottom:2px solid #000}
    .hero .kicker,.hero h1 em,.hero .sub,.chip{color:#000}
    .chip{border-color:#000}
  }
</style>
</head>
<body>

<header class="hero">
  <div class="kicker">Trip Companion · June 10–18, 2026</div>
  <h1>Florida &amp; <em>Greenville</em></h1>
  <div class="sub">Canon visit in Boca Raton, then IPMA 2026 — “Taking Care of Business.”</div>
  <div class="meta">
    <span class="chip">✈︎ 9 days · 8 nights</span>
    <span class="chip">🅿︎ Car parked at SLC</span>
    <span class="chip">🧳 No laundry planned</span>
  </div>
</header>

<nav id="nav">
  <a href="#overview">Overview</a>
  <a href="#flags">Heads-up</a>
  <a href="#schedule">Schedule</a>
  <a href="#eat">Eat</a>
  <a href="#pack">Pack</a>
</nav>

<main>

  <!-- OVERVIEW -->
  <section id="overview">
    <div class="sec-head"><h2>The Itinerary</h2></div>
    <p class="sec-note">Flights, hotels, and the car at a glance.</p>

    <div class="card">
      <h3 class="day"><span class="dot"></span>Wed, Jun 10 <small>SLC → Boca Raton</small></h3>
      <div class="check"><div class="c-body"><span class="c-time">~5:00 AM</span><div class="c-title">Drop car at SLC long-term parking — photo your level/row</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">7:00 AM</span><div class="c-title">UA 1232 · SLC → Denver</div><div class="c-loc">Arrive DEN 8:42 AM · 1h27m layover</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">10:09 AM</span><div class="c-title">UA 1701 · Denver → Miami</div><div class="c-loc">Arrive MIA 4:16 PM EDT</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">6:16 PM</span><div class="c-title">Check in · Boca Raton Marriott at Boca Center</div><div class="c-loc">5150 Town Center Cir · Canon dinner this evening</div></div></div>
    </div>

    <div class="card">
      <h3 class="day"><span class="dot"></span>Fri, Jun 12 <small>Boca → Greenville</small></h3>
      <div class="callout alert" style="margin:4px 0 12px"><strong>Brutal early start.</strong> Checkout 4:20 AM for a 6:20 AM Miami departure. Pre-pack the night before and pre-arrange a 4 AM ride.</div>
      <div class="check"><div class="c-body"><span class="c-time">4:20 AM</span><div class="c-title">Check out · Boca Raton Marriott</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">6:20 AM</span><div class="c-title">WN 974 · Miami → Baltimore</div><div class="c-loc">Arrive BWI 8:55 AM · 2h50m layover</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">11:45 AM</span><div class="c-title">WN 952 · Baltimore → Greenville</div><div class="c-loc">Arrive GSP 1:15 PM</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">3:00 PM</span><div class="c-title">Check in · Hyatt Regency Greenville</div><div class="c-loc">220 N Main St · conference hotel</div></div></div>
    </div>

    <div class="card">
      <h3 class="day"><span class="dot"></span>Thu, Jun 18 <small>Greenville → SLC</small></h3>
      <div class="check"><div class="c-body"><span class="c-time">11:00 AM</span><div class="c-title">Check out · Hyatt Regency (do it before the 8:30 bus — see Heads-up)</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">5:10 PM</span><div class="c-title">UA 4038 · Greenville → Houston</div><div class="c-loc">Arrive IAH 6:45 PM CDT · 1h40m layover</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">8:25 PM</span><div class="c-title">UA 2157 · Houston → SLC</div><div class="c-loc">Arrive SLC 10:43 PM · retrieve car (late-night shuttle)</div></div></div>
    </div>
  </section>

  <!-- FLAGS -->
  <section id="flags">
    <div class="sec-head"><h2>Heads-up</h2></div>
    <p class="sec-note">Four things worth handling before they bite.</p>

    <div class="callout alert">
      <strong>Verify the phantom 6/13 flights.</strong> Your calendar also holds a second United SLC→DEN→GSP booking for Sat 6/13 (conf. LR2Z65) — a leftover from an earlier itinerary. Your real route flies you through Boca and lands you in Greenville Friday. Confirm with your travel desk it's cancelled so it doesn't snarl your reservation.
    </div>
    <div class="callout">
      <strong>Thursday checkout vs. the BJU tour.</strong> Hotel checkout is 11 AM, but the Bob Jones University press-tour bus leaves the lobby at 8:30 AM and returns ~noon. Check out (or set express/late checkout) <em>before</em> the bus, store bags with the bell desk, and you're free until your 5:10 PM flight.
    </div>
    <div class="callout">
      <strong>CPAP travels free.</strong> Your ResMed is a medical device — per TSA it does <em>not</em> count against your two carry-ons. Keep it, your meds, and a change of clothes on you, not in a checked bag. Pack the mask, hose, charger, and a short extension cord.
    </div>
    <div class="callout">
      <strong>Parking note.</strong> Roughly 8 nights at SLC. Snap a photo of your row/level Wednesday morning — you'll be hunting for the car at 11 PM Thursday after a long travel day.
    </div>
  </section>

  <!-- SCHEDULE -->
  <section id="schedule">
    <div class="sec-head"><h2>My IPMA Schedule</h2><span class="prog" id="prog-sched">0 of 0</span></div>
    <div class="barwrap"><div class="bar" id="bar-sched"></div></div>
    <p class="ix">These are the sessions you selected, pulled from your calendar. All times are Greenville (Eastern). Tap to check off; progress saves automatically. The red <span class="cbadge" style="margin:0">Double-booked</span> blocks are slots where you picked two at once — choose one.</p>

    <div class="callout alert"><strong>5 scheduling conflicts to resolve.</strong> You've got two sessions selected in the same slot five times: Sun 3:30, Mon 2:45, Tue 1:45, Wed 10:00, and Wed 2:30. They're grouped and flagged below.</div>

    <div class="card" data-track="sched">
      <h3 class="day"><span class="dot"></span>Sat, Jun 13 <small>Arrival · free evening</small></h3>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">2:00–5:00 PM</span><div class="c-title">Registration</div><div class="c-loc">Meeting Planner Office</div></div></div>
      <div class="check"><div class="c-body"><span class="c-time">Evening</span><div class="c-title">Free — see the Eat tab for your walkable plan</div></div></div>
    </div>

    <div class="card" data-track="sched">
      <h3 class="day"><span class="dot"></span>Sun, Jun 14 <small>Conference opens</small></h3>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">8:00–11:00 AM</span><div class="c-title">Sunday Stroll</div><div class="c-loc">Meet in Lobby</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">2:30–3:30 PM</span><div class="c-title">RSA Users Group</div><div class="c-loc">Regency G</div></div></div>
      <div class="conflict">
        <span class="cbadge">Double-booked · 3:30–4:30 PM</span>
        <div class="check"><div class="box"></div><div class="c-body"><div class="c-title">Canon Focus Group<span class="star">FOR YOU</span></div><div class="c-loc">Redbud · ties to your Boca Canon visit</div></div></div>
        <div class="check"><div class="box"></div><div class="c-body"><div class="c-title">Ricoh Users Group</div><div class="c-loc">Regency F</div></div></div>
      </div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">6:00–9:00 PM</span><div class="c-title">Welcome Reception</div><div class="c-loc">Outdoor Plaza (2nd floor) · dress the part</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">9:00 PM–12 AM</span><div class="c-title">Hospitality Suite</div><div class="c-loc">Suite 864</div></div></div>
    </div>

    <div class="card" data-track="sched">
      <h3 class="day"><span class="dot"></span>Mon, Jun 15 <small>Keynote · sponsored by RSA</small></h3>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">7:30–8:45 AM</span><div class="c-title">Breakfast</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">8:00–8:45 AM</span><div class="c-title">From Toner to Textiles: New Services Driving In-plant Growth</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">9:00–10:00 AM</span><div class="c-title">Keynote Speaker (sponsored by RSA)</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">10:00 AM–12 PM</span><div class="c-title">Vendor Fair</div><div class="c-loc">Regency Ballroom</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">12:00–1:30 PM</span><div class="c-title">Lunch</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">12:30–1:30 PM</span><div class="c-title">Ricoh: From Touchpoints to Throughput<span class="star">FOR YOU</span></div><div class="c-loc">Studio 200 @ NOMA · lunch session</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">1:45–2:30 PM</span><div class="c-title">Roundtable: West Region<span class="star">FOR YOU</span></div><div class="c-loc">Dogwood · UT/CO/NV/CA/OR/WA/ID/MT/WY (your region)</div></div></div>
      <div class="conflict">
        <span class="cbadge">Double-booked · 2:45–3:30 PM</span>
        <div class="check"><div class="box"></div><div class="c-body"><div class="c-title">A Postal Primer for Printers<span class="star">FOR YOU</span></div><div class="c-loc">Regency H · pairs with your mail-consolidation work</div></div></div>
        <div class="check"><div class="box"></div><div class="c-body"><div class="c-title">What Print Providers Should Measure to Improve Operations &amp; Prepare for AI<span class="star">FOR YOU</span></div><div class="c-loc">Redbud</div></div></div>
      </div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">4:30–6:30 PM</span><div class="c-title">Vendor Reception</div><div class="c-loc">Grand Ballroom BC</div></div></div>
    </div>

    <div class="card" data-track="sched">
      <h3 class="day"><span class="dot"></span>Tue, Jun 16 <small>Keynote · Nathaniel Hearne · Awards night</small></h3>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">7:30–8:45 AM</span><div class="c-title">Breakfast</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">8:00–8:45 AM</span><div class="c-title">Marketing Your In-Plant</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">9:00–10:00 AM</span><div class="c-title">Keynote: Nathaniel Hearne — The Courage to Leave a Legacy</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">12:00–1:30 PM</span><div class="c-title">Lunch</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">12:30–1:30 PM</span><div class="c-title">Built to Last: Future-Proofing Your In-Plant<span class="star">FOR YOU</span></div><div class="c-loc">Studio 200 @ NOMA · lunch session</div></div></div>
      <div class="conflict">
        <span class="cbadge">Double-booked · 1:45–2:30 PM</span>
        <div class="check"><div class="box"></div><div class="c-body"><div class="c-title">Responsibilities of Leaders (Panel)<span class="star">FOR YOU</span></div><div class="c-loc">Regency G</div></div></div>
        <div class="check"><div class="box"></div><div class="c-body"><div class="c-title">The Rise of the Virtual Promo Products Department</div><div class="c-loc">Regency H</div></div></div>
      </div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">4:00–5:00 PM</span><div class="c-title">Vendor Door Prizes</div><div class="c-loc">Regency Ballroom</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">5:30–7:00 PM</span><div class="c-title">Awards Reception</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">7:00–7:45 PM</span><div class="c-title">Awards Dinner Banquet<span class="star">FOR YOU</span></div><div class="c-loc">Studio 200 @ NOMA · dressiest night</div></div></div>
      <div class="check"><div class="box"></div><div class="c-body"><span class="c-time">7:45–9:45 PM</span><div class="c-title">Awards Ceremony</div><div class="c-loc">Studio 200 @ NOMA</div></div></div>
    </div>

    <div class="card" data-track="sched">
